# ── OpenRouter (existant) ──────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Driver asyncpg pour SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pharmadb
# Driver psycopg3 pour LangGraph checkpointer
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/pharmadb

# ── JWT ───────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<secret here>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
